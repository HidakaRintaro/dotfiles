[tools]
aws = "latest"
go = "latest"
jq = "latest"
node = "latest"
npm = "latest"
php = "latest"
pinact = "latest"
{{ if eq .chezmoi.arch "arm64" -}}
pnpm = "latest"
{{ else -}}
# aqua:pnpm/pnpm はdarwin/amd64(Intel mac)非対応のため、Intelではnpmバックエンドを使う。
"npm:pnpm" = "latest"
{{ end -}}
python = "latest"
terraform = "latest"
yarn = "1"

[tool_alias]
php = "vfox:mise-plugins/vfox-php"

[settings]
minimum_release_age = "7d"
disable_backends = ["asdf"]
idiomatic_version_file_enable_tools = ["go", "node", "npm", "php", "pnpm", "python", "yarn"]
