[user]
	name  = {{ .github_username }}
	email = {{ .github_email }} 
	signingkey = 38B20DFB72BB2BF0

[alias]
	b   = branch
	bnm = branch --no-merged
	bmd = delete-merged-branches
	bsd = delete-squashed-branches
	bd  = "!git bmd && git bsd"
	cm  = commit
	co  = checkout
	ft  = fetch
	ftp = fetch --prune
	gr  = log --graph --date=short --decorate=short --pretty=format:'%Cgreen%h %Creset%cd %Cblue%cn %Cred%d %Creset%s'
	p   = push
	po  = push origin
	puo = push -u origin
	st  = status
	sw  = switch

[commit]
	gpgsign = true

[url "git@github.com:"]
	insteadOf = git://github.com/
	insteadOf = https://github.com/
[url "git@gist.github.com:"]
	pushInsteadOf = https://gist.github.com/
