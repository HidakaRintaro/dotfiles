source_if_exists () {
  if [[ -f "$1" ]]; then
    source "$1"
  fi
}

source_if_exists $HOME/.config/zsh/homebrew.zsh
source_if_exists $HOME/.config/zsh/aliases.zsh
source_if_exists $HOME/.config/zsh/starship.zsh

# Load Starship
eval "$(starship init zsh)"

autoload -Uz compinit && compinit  # 補完機能を有効にする
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'  # 小文字でも大文字ディレクトリ、ファイルを補完できるようにする

# Claude
export PATH="$HOME/.claude/local:$PATH"

# Load mise
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
elif [[ -x "$HOME/.local/bin/mise" ]]; then
  eval "$("$HOME/.local/bin/mise" activate zsh)"
fi
